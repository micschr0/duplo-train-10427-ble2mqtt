# MQTT Broker Configuration
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=duplo-train-gateway
MQTT_BASE_TOPIC=duplo/train

# Motor Configuration
MOTOR_FORWARD=50
MOTOR_BOOST=75
# Boost duration in seconds (0 or empty = unlimited)
MOTOR_BOOST_DURATION=
MOTOR_BACKWARD=-50
BACKWARD_DELAY=1200

# Logging level (trace, debug, info, warn, error)
RUST_LOG=info,duplo_train_controller=debug
